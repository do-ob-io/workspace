{
  "name": "do-ob-io",
  "version": "1.0.0",
  "description": "Workspace for do-ob npm NodeJS projects",
  "private": true,
  "engines": {
    "node": "25"
  },
  "scripts": {
    "lint": "eslint --fix",
    "test": "vitest run",
    "typedoc": "typedoc --options ./typedoc.json",
    "typedoc2": "pnpm run -r --if-present typedoc",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "workspaces": [
    "nodejs/*"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint-react/eslint-plugin": "catalog:eslint",
    "@eslint/js": "catalog:eslint",
    "@faker-js/faker": "^10.4.0",
    "@react-three/drei": "catalog:react",
    "@react-three/fiber": "catalog:react",
    "@rolldown/plugin-babel": "catalog:vite",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/addon-vitest": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@stylistic/eslint-plugin": "catalog:eslint",
    "@tailwindcss/vite": "catalog:vite",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "@vitest/browser-playwright": "catalog:vite",
    "@vitest/coverage-v8": "catalog:vite",
    "eslint": "catalog:eslint",
    "eslint-import-resolver-typescript": "catalog:eslint",
    "eslint-plugin-better-tailwindcss": "catalog:eslint",
    "eslint-plugin-depend": "catalog:eslint",
    "eslint-plugin-import-x": "catalog:eslint",
    "eslint-plugin-react-hooks": "catalog:eslint",
    "eslint-plugin-react-refresh": "catalog:eslint",
    "eslint-plugin-storybook": "catalog:eslint",
    "eslint-plugin-unicorn": "catalog:eslint",
    "globals": "catalog:eslint",
    "happy-dom": "^20.8.3",
    "playwright": "^1.59.1",
    "postcss": "^8.5.9",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "shadcn": "^4.2.0",
    "storybook": "catalog:storybook",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint",
    "vite": "catalog:vite",
    "vitest": "catalog:vite"
  },
  "resolutions": {
    "sharp": "^0.33.5",
    "sharp-ico": "^0.1.5"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "$vite"
    },
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
