{
  "name": "do-ob-io",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace for do-ob npm NodeJS projects",
  "license": "ISC",
  "author": "",
  "workspaces": [
    "nodejs/*"
  ],
  "scripts": {
    "build-storybook": "storybook build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "test:browser": "vitest run --project browser",
    "test:node": "vitest run --project node",
    "test:storybook": "vitest run --project storybook",
    "typedoc": "typedoc --options ./typedoc.json",
    "typedoc2": "pnpm run -r --if-present typedoc"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint-react/eslint-plugin": "catalog:eslint",
    "@faker-js/faker": "^10.4.0",
    "@react-three/drei": "catalog:react",
    "@react-three/fiber": "catalog:react",
    "@rolldown/plugin-babel": "catalog:vite",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/addon-vitest": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@tailwindcss/vite": "catalog:vite",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "@vitest/browser-playwright": "catalog:vite",
    "@vitest/coverage-v8": "catalog:vite",
    "eslint-plugin-better-tailwindcss": "catalog:eslint",
    "eslint-plugin-depend": "catalog:eslint",
    "eslint-plugin-storybook": "catalog:eslint",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.20.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "shadcn": "^4.10.0",
    "storybook": "catalog:storybook",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite",
    "vitest": "catalog:vite"
  },
  "resolutions": {
    "sharp": "^0.33.5",
    "sharp-ico": "^0.1.5"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "$vite"
    },
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "engines": {
    "node": "26.3.0"
  }
}
